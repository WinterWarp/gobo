[Unit]
Description=Gobo attention manager (Planner + Manager bots)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=gobo
WorkingDirectory=/opt/gobo
EnvironmentFile=/etc/gobo.env
ExecStart=/usr/local/bin/uv run python -m gobo
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
