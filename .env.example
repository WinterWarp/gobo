# Telegram bot tokens (create two bots via @BotFather)
PLANNER_BOT_TOKEN=
MANAGER_BOT_TOKEN=

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Your numeric Telegram user id (e.g. from @userinfobot). Both bots ignore everyone else.
ALLOWED_TELEGRAM_USER_ID=

# Optional dev knobs:
# GOBO_CONFIG=config.toml
# GOBO_TIME_SCALE=60        # virtual time runs 60x faster (testing)
